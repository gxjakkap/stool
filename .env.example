# OIDC
OIDC_ISSUER=https://your-oidc-provider.example.com
OIDC_CLIENT_ID=stool
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:4000/auth/callback

# App
APP_SECRET=change-me-to-a-long-random-secret
BACKEND_PORT=4000
FRONTEND_PORT=3000

# Initial channel configuration (can also be set via the Settings UI)
TWITCH_CHANNEL=
YOUTUBE_CHANNEL_ID=
YOUTUBE_API_KEY=
TIKTOK_USERNAME=

# Gemini TTS (optional — enables TTS audio in donation overlay)
GEMINI_API_KEY=
